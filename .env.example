# RepoAlpha — .env.example (Enterprise)
# ── Bright Data ─────────────────────────────────────────────────────────────
# Dashboard: https://brightdata.com → Account Settings → API Token
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here
# Proxies & Scraping → Web Unlocker → zone name + credentials
BRIGHTDATA_CUSTOMER_ID=hl_xxxxxxx
BRIGHTDATA_ZONE=web_unlocker1
BRIGHTDATA_ZONE_PASSWORD=your_zone_password_here
# Pre-built GitHub Trending dataset (no custom scraper needed)
BRIGHTDATA_DATASET_ID=gd_goodboy

# ── Groq ────────────────────────────────────────────────────────────────────
# https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_groq_key_here

# ── Supabase ────────────────────────────────────────────────────────────────
# https://supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here   # service_role for agents (bypasses RLS)
# Dashboard uses anon key (read-only, set in .streamlit/secrets.toml)

# ── GitHub PAT (optional but strongly recommended) ────────────────────────
# Without: 60 req/hr  |  With: 5,000 req/hr
# https://github.com/settings/tokens → Generate (no scopes needed)
GITHUB_TOKEN=ghp_your_pat_here

# ── Alerting (all optional — leave blank to disable) ─────────────────────
# Slack:   workspace → Apps → Incoming Webhooks → Add
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# Discord: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
# Resend:  https://resend.com → API Keys → Create (100 emails/day free)
RESEND_API_KEY=re_your_resend_key_here
ALERT_EMAIL_TO=analyst@yourfirm.com
ALERT_EMAIL_FROM=alerts@repoalpha.dev

# ── Alert thresholds ────────────────────────────────────────────────────────
ALERT_BUY_THRESHOLD=60    # corporate_score must exceed this to fire a BUY alert

# ── FastAPI ─────────────────────────────────────────────────────────────────
# Used by the dashboard to deep-link to Swagger docs
API_URL=http://localhost:8000   # change to your Render URL in production
